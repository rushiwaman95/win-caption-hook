{
  "manifest_version": 3,
  "name": "Ask Gemini - Sidebar",
  "version": "1.0",
  "description": "Select text and ask Gemini in sidebar",
  "permissions": ["storage", "activeTab", "system.display"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["popup.css"]
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["gemini-inject.js"],
      "run_at": "document_idle"
    }
  ]
}